---
import heroGeneral    from "../../../assets/hero-general.png"; // 👈 imagen slide 1
import heroYessica   from "../../../assets/yessicaservicios.png"; // 👈 reemplaza con tu imagen slide 2
import heroTecnologia from "../../../assets/hero-servicios.png"; // 👈 reemplaza con tu imagen slide 3

import HeroServiciosSlider from "../../ui/HeroServiciosSlider.astro";

const slides = [
  /* ── 1. General de la clínica ──────────────────────────────────── */
  {
    image: heroGeneral,
    alt: "Clínica Maxilodental Studio — atención odontológica integral",
    title: "Odontología integral que",
    titleHighlight: "cuida cada detalle de tu sonrisa",
    description:
      "En Maxilodental Studio combinamos tecnología de vanguardia, atención cercana y tratamientos de alta precisión para ofrecerte una experiencia odontológica cómoda, segura y con resultados naturales.",
    primaryCta: {
      label: "Ver todos los servicios",
      href: "#servicios",
    },
    secondaryCta: {
      label: "Agenda tu valoración",
      href: "/contacto",
    },
    floatingCard: {
      label: "Clínica integral",
      text: "Atención cálida y resultados naturales",
    },
    cards: [
      {
        label: "Confianza",
        text: "Acompañamiento cercano y orientación clara durante todo el proceso.",
      },
      {
        label: "Calma",
        text: "Una experiencia tranquila, humana y bien explicada desde el inicio.",
      },
      {
        label: "Resultados",
        text: "Sonrisas naturales y experiencias que generan seguridad y satisfacción.",
      },
    ],
    tags: ["Testimonios reales", "Atención personalizada", "Resultados naturales"],
  },

  /* ── 2. Servicios especializados ───────────────────────────────── */
  {
    image: heroYessica,
    alt: "Servicios odontológicos especializados en Maxilodental Studio",
    title: "Tratamientos avanzados para",
    titleHighlight: "transformar tu salud oral",
    description:
      "Implantes dentales, prótesis híbridas, cirugía ortognática, toxina botulínica para bruxismo, carillas estéticas y cirugía de cordales. Procedimientos de alta complejidad con acompañamiento profesional en cada etapa.",
    primaryCta: {
      label: "Ver servicios especializados",
      href: "#servicios",
    },
    secondaryCta: {
      label: "Agenda una valoración",
      href: "/contacto",
    },
    floatingCard: {
      label: "Alta especialización",
      text: "Cirugía, implantes y rehabilitación oral",
    },
    cards: [
      {
        label: "Implantes y prótesis",
        text: "Reemplazo de piezas con resultados estéticos y funcionales duraderos.",
      },
      {
        label: "Cirugía ortognática",
        text: "Corrección de maxilares para mejorar función masticatoria y armonía facial.",
      },
      {
        label: "Toxina botulínica",
        text: "Manejo de bruxismo, sonrisa gingival y arrugas de expresión con precisión.",
      },
    ],
    tags: ["Implantes dentales", "Prótesis híbridas", "Cirugía de cordales"],
  },
  {
    image: heroTecnologia,
    alt: "Radiografía dental sostenida por manos con guantes",
    title: "Odontología Estética y",
    titleHighlight: "Rehabilitación Digital",
    description:
      "Tratamientos precisos, armónicos y naturales, planificados con enfoque digital para lograr resultados funcionales, estéticos y bien integrados a tu sonrisa.",
    primaryCta: {
      label: "Ver tratamientos",
      href: "#servicios1",
    },
    secondaryCta: {
      label: "Agenda tu valoración",
      href: "/contacto",
    },
    floatingCard: {
      label: "Planificación precisa",
      text: "Diagnóstico digital y resultados armónicos",
    },
    cards: [
      {
        label: "Precisión",
        text: "Diagnóstico y planificación con apoyo digital.",
      },
      {
        label: "Armonía",
        text: "Resultados naturales pensados para tu rostro y sonrisa.",
      },
      {
        label: "Cercanía",
        text: "Atención personalizada en cada etapa del tratamiento.",
      },
    ],
    tags: ["Especialistas", "Tecnología digital", "Atención personalizada"],
  },
  
  
  
  


  
];
---

<HeroServiciosSlider slides={slides} autoplay={true} interval={6500} />